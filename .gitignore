# Built binary of the plugin, produced by `go build ./cmd/protoc-gen-go-const`.
#
# The leading slash anchors this rule to the repository root, so it matches
# the 8MB binary that lands next to README.md but NOT the same-named Go
# package directory at cmd/protoc-gen-go-const/ (which is a directory in a
# different path and therefore cannot collide with this pattern).
/protoc-gen-go-const

# Built binary of the nilcompare analyzer, produced by
# `go build ./cmd/nilcompare`. Root-anchored for the same reason as above:
# the rule matches the binary next to README.md, not the Go package
# directory at cmd/nilcompare/.
/nilcompare

# Common Go build / test artifacts.
*.test
*.out
coverage.txt
coverage.html
